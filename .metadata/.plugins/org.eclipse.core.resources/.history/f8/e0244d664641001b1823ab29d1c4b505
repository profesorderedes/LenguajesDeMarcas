<?xml version="1.0" encoding="UTF-8"?>

<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">

	<xs:element name="tourGuide">
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="city" maxOccurs="unbounded"></xs:element>
			</xs:sequence>
		</xs:complexType>
	</xs:element>

	<xs:element name="city">
		<xs:complexType>
			<xs:all>
				<xs:element ref="cityName"></xs:element>
				<xs:element ref="adminUnit"></xs:element>
				<xs:element ref="country"></xs:element>
				<xs:element ref="population"></xs:element>
				<xs:element ref="area"></xs:element>
				<xs:element ref="elevation"></xs:element>
				<xs:element ref="longitude"></xs:element>
				<xs:element ref="latitude"></xs:element>
				<xs:element ref="description"></xs:element>
				<xs:element ref="history"></xs:element>
			</xs:all>
		</xs:complexType>
	</xs:element>

	<xs:element name="cityName" type="xs:string"></xs:element>

	<xs:element name="adminUnit" type="xs:string"></xs:element>

	<xs:element name="country" type="xs:string"></xs:element>

	<xs:element name="population" type="xs:positiveInteger"></xs:element>

	<xs:element name="area" type="xs:positiveInteger"></xs:element>

	<xs:element name="elevation" type="xs:positiveInteger"></xs:element>

	<xs:element name="longitude" type="xs:decimal"></xs:element>

	<xs:element name="latitude" type="xs:decimal"></xs:element>

	<xs:element name="description" type="xs:string"></xs:element>

	<xs:element name="history" type="xs:string"></xs:element>




</xs:schema>