<?xml version="1.0" encoding="UTF-8" ?>

<receta xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:noNamespaceSchemaLocation="receta.xsd">
	
	<medicamento>Paracetamol</medicamento>
	<medicamento>Ibuprofeno</medicamento>
	
	<!-- El contenido de farmacia, si no se especifica, será "Farmacia Juaneda" -->
	<farmacia>Farmacia IES Son Ferrer</farmacia>
	
	<!-- La edad de un paciente puede ser mayor o igual a 0, 
		y menor o igual a 150 -->
	<edad>70</edad>
	
	<!-- El nombre del paciente no deberá exceder de 50 caracteres -->
	<nombre>Francisco Santos</nombre>
	
	<!-- El elemento pago puede ser: Gratuito, Copago o Íntegro -->
	<pago>Gratuito</pago>
	
	<!-- El elemento dni debe ser 8 cifras seguidas de una letra mayúscula-->
	<dni>19102001H</dni>

	<!-- El elemento numColegiado tiene un atributo de tipo integer  -->	
	<medico numColegiado="287368">Juan Luque</medico>
	
	<!-- El elemento posologia contiene dos elementos hijos, tomas y horario -->
	<posologia>
		<tomas>3</tomas>
		<horario>Tomar en el desayuno, comida y cena.</horario>
	</posologia>
	
	<!-- El elemento alergias siempre estará vacío -->
	<alergias/>
	
	
</receta>



















