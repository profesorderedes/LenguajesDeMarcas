<?xml version="1.0" ?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">
	<xs:element name="subasta">
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="objeto" />
			</xs:sequence>
			<xs:attribute ref="descripcion" use="required" />
		</xs:complexType>
	</xs:element>

	<xs:attribute name="descripcion" type="xs:string" />

	<xs:element name="objeto">
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="propietario" />
				<xs:element ref="precioSalida" />
				<xs:element ref="precioMin" minOccurs="0" />
			</xs:sequence>
		</xs:complexType>
	</xs:element>

	<xs:element name="propietario" type="xs:string" />
	<xs:element name="precioSalida" type="typeSalida" />
	<xs:element name="precioMin" type="xs:decimal" />

	<xs:simpleType name="typeSalida">
		<xs:restriction base="xs:decimal">
			<xs:totalDigits value="6" />
		</xs:restriction>
	</xs:simpleType>


</xs:schema>