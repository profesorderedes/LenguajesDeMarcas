<?xml version="1.0" encoding="UTF-8" ?>

<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">

	<xs:element name="subasta">
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="objeto" maxOccurs="unbounded" />
			</xs:sequence>
		</xs:complexType>
	</xs:element>

	<xs:element name="objeto">
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="propietario" />
				<xs:element ref="precioSalida" />
				<xs:element ref="precioMin" />
			</xs:sequence>
			<xs:attribute ref="descripcion" />
		</xs:complexType>
	</xs:element>

	<xs:attribute name="descripcion" type="xs:string"/>

	<xs:element name="propietario" type="xs:string"/>

	<xs:element name="precioSalida" />

	<xs:element name="precioMin" />

</xs:schema>