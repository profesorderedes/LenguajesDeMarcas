<?xml version="1.0" encoding="UTF-8" ?>

<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">

	<xs:element name="reserva">
		<xs:complexType>
			<xs:sequence>

				<xs:element name="cliente">
					<xs:complexType>
						<xs:sequence>
							<xs:element name="apellidos" type="xs:string" />
							<xs:element name="nombre" type="xs:string" />
							<xs:element name="tel" type="xs:string" />
						</xs:sequence>
					</xs:complexType>
				</xs:element>

				<xs:choice>

					<xs:element name="avion">
						<xs:complexType>
							<xs:complexContent>
								<xs:extension base="TipoFechas">
									
								</xs:extension>
							</xs:complexContent>
						</xs:complexType>
					</xs:element>

					<xs:element name="barco" type="TipoFechas"/>

				</xs:choice>

			</xs:sequence>
		</xs:complexType>
	</xs:element>

	<xs:complexType name="TipoFechas">
		<xs:sequence>
			<xs:element name="salida" type="xs:date" />
			<xs:element name="llegada" type="xs:date" />
		</xs:sequence>
	</xs:complexType>

</xs:schema>




