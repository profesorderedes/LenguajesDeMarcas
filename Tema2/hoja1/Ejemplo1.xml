<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE sistema [

    <!ELEMENT sistema (planeta*, estrella?)>
    <!ELEMENT planeta (#PCDATA)>
    <!ELEMENT estrella (#PCDATA)>

]>

<!-- El elemento sistema debe tener uno o más planetas. Y puede tener, o no, una estrella.-->
<sistema>
    <planeta>Marte</planeta>
    <planeta>Plutón</planeta>
    <estrella>Sol</estrella>
</sistema>
