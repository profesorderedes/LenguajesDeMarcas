<!-- Ejemplo de entidades para utilizar caracteres especiales -->
<etiquetas>

	<etiqueta>
	    <!-- Etiqueta h1 -->
		<nombre>&lt;h1&gt;</nombre>
		<descripcion>Título principal de la página</descripcion>
	</etiqueta>
	
	<etiqueta>
	    <!-- Etiqueta h2 -->
		<nombre>&lt;h2&gt;</nombre>
		<descripcion>Título secundario</descripcion>
	</etiqueta>
	

</etiquetas>
